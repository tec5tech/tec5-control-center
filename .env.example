# Copia este archivo como .env y completá los valores
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tec5_portal?schema=public"

# Auth.js v5
AUTH_SECRET="genera-uno-con: openssl rand -base64 32"
AUTH_TRUST_HOST=true
NEXTAUTH_URL="http://localhost:3000"

# Seed admin por defecto
SEED_ADMIN_EMAIL="admin@tec5.tech"
SEED_ADMIN_PASSWORD="Tec5!Admin2026"
# Bearer token para autenticar el cron de sincronización automática.
# Generá uno con: openssl rand -hex 32
CRON_SECRET=
